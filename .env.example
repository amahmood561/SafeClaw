# Use OpenAI-compatible API endpoint
# Provider presets: openai, ollama, groq, openrouter, litellm, custom
SAFECLAW_PROVIDER_PRESET=openai
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Agent settings
WORKSPACE=./workspace
ALLOW_SHELL=false
SAFECLAW_PERMISSION_PROFILE=readonly
SAFECLAW_APPROVAL_MODE=ask
MAX_TOOL_STEPS=6

# Optional read-only SQLite databases.
# Paths are relative to WORKSPACE and must stay inside it.
# Example: SAFECLAW_SQLITE_DATABASES=app=app.db,notes=data/notes.db
SAFECLAW_SQLITE_DATABASES=

# Optional Twilio WhatsApp outbound support.
# For inbound replies, point your Twilio WhatsApp webhook to:
#   https://your-public-url/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
SAFECLAW_ALLOWED_SENDERS=

# Optional Telegram phone access.
# Install Telegram, create a bot with the verified @BotFather account,
# paste the token, optionally allowlist your numeric user ID, then run:
#   safeclaw telegram
TELEGRAM_BOT_TOKEN=
SAFECLAW_ALLOWED_TELEGRAM_USERS=
